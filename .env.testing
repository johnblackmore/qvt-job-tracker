# .env.testing — Safe test environment
# Uses SQLite in-memory database. NEVER connects to the real MySQL database.
APP_NAME="QVT Job Tracker (Testing)"
APP_ENV=testing
APP_KEY=base64:fmLW8yA1VTlpc2MxOVmf9BCnm5CZo+j3k1hmg1W+8j8=
APP_DEBUG=true
APP_URL=http://localhost

# 🚨 SAFETY: In-memory SQLite — completely destroyed after each test
# This ensures tests NEVER touch real business data in MySQL
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BCRYPT_ROUNDS=4
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=null

LOG_CHANNEL=stack
LOG_LEVEL=debug

# AI providers — disabled in tests
OPENROUTER_API_KEY=
OPENCODE_API_KEY=
GROQ_API_KEY=

# Monzo — disabled in tests
MONZO_CLIENT_ID=
MONZO_CLIENT_SECRET=
MONZO_REDIRECT_URI=

# Netlify — dummy values for tests
NETLIFY_API_TOKEN=test-token
NETLIFY_SITE_ID=test-site-id
NOTIFICATION_EMAIL=test@example.com
